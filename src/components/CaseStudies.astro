---
import { Image } from "astro:assets";
import ntensewrapTh from "../assets/thumbnail-nw.jpg";
import drawpointTh from "../assets/thumbnail-drawpoint.png";

const studies = [
  {
    tag: "Case Study: Vehicle Styling",
    title: "Ntensewrap",
    description: "Brand website for a professional vehicle styling company specializing in vinyl wraps, commercial fleet branding, and paint protection films (PPF).",
    logo: ntensewrapTh,
  },
  {
    tag: "Case Study: Web Tool",
    title: "Drawpoint",
    description: "A no-code platform that lets you create, customize, and embed interactive maps and images into any website — no developers required.",
    logo: drawpointTh,
  },
];
---

{studies.map((study) => (
  <div class="md:col-span-6 glass-card rounded-xl overflow-hidden group inner-highlight">
    <div class="h-72 bg-surface-container-highest relative overflow-hidden">
      <Image
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
        alt={study.title}
        src={study.logo}
      />
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface-container-highest/80 pointer-events-none" />
      <div class="absolute top-6 left-6">
        <span class="bg-black/60 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-[0.2em] text-white border border-white/10">
          {study.tag}
        </span>
      </div>
    </div>
    <div class="p-10">
      <h4 class="font-headline text-2xl font-bold mb-3">{study.title}</h4>
      <p class="text-on-surface-variant text-sm mb-8 leading-relaxed">{study.description}</p>
      <a class="text-primary text-xs font-bold uppercase tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all" href="#">
        Explore Technical Breakdown <span class="material-symbols-outlined text-sm">north_east</span>
      </a>
    </div>
  </div>
))}
