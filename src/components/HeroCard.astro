---

<div class="md:col-span-8 glass-card rounded-xl p-8 md:p-14 flex flex-col justify-end relative overflow-hidden min-h-[480px] inner-highlight">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-transparent pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-[120px] -mr-48 -mt-48"></div>
  <div class="relative z-10">
    <span class="font-label text-[10px] tracking-[0.2em] text-primary font-bold uppercase mb-6 block">
      Product-Focused Software Engineer
    </span>
    <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.05]">
      Engineering systems that help businesses <span class="text-primary">scale.</span>
    </h1>
    <div class="flex flex-wrap items-center gap-6">
      <button class="text-white px-8 py-4 rounded-lg font-bold text-sm flex items-center gap-3 neon-glow-primary hover:neon-glow-hover transition-all transform hover:-translate-y-1 cta-gradient">
        View Portfolio <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </button>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-on-surface-variant text-sm font-medium tracking-tight">Available for new projects</span>
      </div>
    </div>
  </div>
</div>
