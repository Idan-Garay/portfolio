---
const links = [
  // { label: "Github", href: "#" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/idan-joshua-garay/" },
];
---

<footer class="border-t border-white/5 mt-12 bg-transparent">
  <div
    class="max-w-7xl mx-auto px-8 py-16 flex flex-col md:flex-row justify-between items-center w-full gap-8"
  >
    <div class="flex flex-col items-center md:items-start gap-2">
      <span
        class="font-headline font-extrabold text-primary tracking-tighter text-lg"
        >.Dev</span
      >
      <span
        class="font-body text-[10px] tracking-[0.2em] uppercase text-zinc-500"
        >&copy; {new Date().getFullYear()} Idan Joshua. Built with care.</span
      >
    </div>
    <div class="flex gap-10 items-center">
      {
        links.map((link) => (
          <a
            class="font-body text-xs font-bold tracking-[0.15em] uppercase text-zinc-500 hover:text-primary transition-colors"
            href={link.href}
            target="_blank"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
