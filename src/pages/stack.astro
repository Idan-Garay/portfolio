---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const categories = [
  {
    icon: "computer",
    label: "Frontend",
    span: "md:col-span-7",
    tools: [
      { icon: "hub",           label: "React" },
      { icon: "deployed_code", label: "Next.js" },
      { icon: "style",         label: "Tailwind CSS" },
      { icon: "widgets",       label: "Shadcn UI" },
      { icon: "data_object",   label: "TypeScript" },
    ],
  },
  {
    icon: "dns",
    label: "Backend",
    span: "md:col-span-5",
    tools: [
      { icon: "terminal",      label: "Node.js" },
      { icon: "api",           label: "NestJS" },
      { icon: "route",         label: "Express" },
    ],
  },
  {
    icon: "cloud",
    label: "Infrastructure",
    span: "md:col-span-4",
    tools: [
      { icon: "cloud_upload",  label: "Vercel" },
      { icon: "cloud_sync",    label: "AWS" },
      { icon: "cloud_done",    label: "Azure" },
    ],
  },
  {
    icon: "storage",
    label: "Database",
    span: "md:col-span-4",
    tools: [
      { icon: "table_chart",   label: "PostgreSQL" },
      { icon: "table_chart",   label: "MySQL" },
      { icon: "database",      label: "MongoDB" },
    ],
  },
  {
    icon: "cable",
    label: "Integrations",
    span: "md:col-span-4",
    tools: [
      { icon: "payments",      label: "Stripe" },
      { icon: "account_balance_wallet", label: "PayPal" },
      { icon: "webhook",       label: "Webhooks / APIs" },
    ],
  },
];
---

<Layout>
  <Nav />

  <main class="max-w-7xl mx-auto px-6 pt-40 pb-24">

    <!-- Header -->
    <div class="max-w-2xl mb-16 space-y-4">
      <span class="font-label text-[10px] tracking-[0.25em] text-primary font-bold uppercase">Tech Stack</span>
      <h1 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.08]">
        Tools I Build With
      </h1>
      <p class="text-on-surface-variant text-base leading-relaxed">
        The tools and technologies I use to build scalable, reliable systems — chosen for performance and long-term maintainability.
      </p>
    </div>

    <!-- Stack grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6" data-grid-animate>

      {categories.map((cat) => (
        <div class={`${cat.span} glass-card rounded-2xl p-8 inner-highlight`}>
          <!-- Category header -->
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">{cat.icon}</span>
            </div>
            <h2 class="font-headline text-lg font-bold">{cat.label}</h2>
          </div>

          <!-- Tools -->
          <div class="flex flex-wrap gap-2">
            {cat.tools.map((tool) => (
              <span class="flex items-center gap-2 bg-white/5 border border-white/8 hover:border-primary/30 hover:bg-primary/5 text-on-surface-variant hover:text-white text-xs font-bold px-3 py-2 rounded-lg transition-all">
                <span class="material-symbols-outlined text-sm text-primary">{tool.icon}</span>
                {tool.label}
              </span>
            ))}
          </div>
        </div>
      ))}

      <!-- Philosophy -->
      <div class="md:col-span-12 glass-card rounded-2xl p-10 md:p-14 inner-highlight relative overflow-hidden flex flex-col md:flex-row items-center gap-8">
        <div class="absolute inset-0 bg-primary/3 pointer-events-none" />
        <div class="absolute -top-24 -right-24 w-72 h-72 bg-primary/8 rounded-full blur-[100px]" />

        <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0 relative z-10">
          <span class="material-symbols-outlined text-primary text-2xl">lightbulb</span>
        </div>

        <div class="relative z-10 space-y-2">
          <p class="font-label text-[10px] tracking-[0.25em] text-primary font-bold uppercase">Philosophy</p>
          <p class="font-headline text-lg md:text-xl font-bold text-white leading-snug">
            I choose tools based on scalability, performance, and long-term maintainability — not trends.
          </p>
          <p class="text-on-surface-variant text-sm leading-relaxed max-w-2xl">
            Every technology on this page has been used in production. I pick what solves the problem well, not what's popular this month.
          </p>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
